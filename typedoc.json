{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs/api",
  "tsconfig": "tsconfig.typedoc.json",
  "name": "@iankressin/contract-state",
  "readme": "none",
  "excludeInternal": true,
  "excludePrivate": true,
  "excludeExternals": true,
  "includeVersion": true,
  "githubPages": false,
  "hideGenerator": true,
  "sort": ["source-order"],
  "categorizeByGroup": true,
  "navigation": {
    "includeCategories": true,
    "includeGroups": true
  },
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": false
  },
  "intentionallyNotExported": ["MapTracker", "Decoded"],
  "externalSymbolLinkMappings": {
    "@iankressin/contract-state": {
      "BuilderConfigView": "https://github.com/iankressin/contract-state-reproduction/blob/main/src/builder.ts",
      "defaultRetryPolicy": "https://github.com/iankressin/contract-state-reproduction/blob/main/src/resilience.ts",
      "defaultIsRetryable": "https://github.com/iankressin/contract-state-reproduction/blob/main/src/resilience.ts"
    },
    "typescript": {
      "DateConstructor.now": "https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Date/now",
      "Math.random": "https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Math/random"
    }
  }
}
