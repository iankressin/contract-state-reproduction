{
  "name": "@iankressin/contract-state",
  "version": "0.1.0",
  "description": "EVM contract historical state reproduction — streams a contract's storage diffs into an append-only Postgres DB (Subsquid Pipes SDK)",
  "license": "MIT",
  "author": "iankressin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iankressin/contract-state-reproduction.git"
  },
  "homepage": "https://github.com/iankressin/contract-state-reproduction#readme",
  "bugs": {
    "url": "https://github.com/iankressin/contract-state-reproduction/issues"
  },
  "keywords": [
    "ethereum",
    "evm",
    "storage",
    "state",
    "subsquid",
    "pipes",
    "drizzle",
    "indexer",
    "blockchain"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.15.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run tests/unit tests/integration/pipeline.test.ts",
    "test:cov": "vitest run --coverage tests/unit tests/integration/pipeline.test.ts",
    "test:e2e": "RUN_E2E=1 vitest run tests/integration/e2e.test.ts tests/integration/uniswap.test.ts",
    "test:net": "RUN_NET=1 vitest run tests/unit/layout.test.ts",
    "example": "tsx examples/dai.ts",
    "example:uniswap": "tsx examples/uniswap-v3-pool.ts",
    "smoke": "tsx scripts/smoke-statediffs.ts",
    "verify": "tsx scripts/verify-values.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@subsquid/pipes": "1.0.0-alpha.9",
    "viem": "^2.46.3"
  },
  "peerDependencies": {
    "drizzle-orm": "0.44.7",
    "pg": "8.16.3",
    "solc": "^0.8.28"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "solc": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/cli": "2.31.0",
    "@types/node": "^22.10.0",
    "@types/pg": "8.15.6",
    "@vitest/coverage-v8": "3.2.4",
    "drizzle-orm": "0.44.7",
    "madge": "^8.0.0",
    "pg": "8.16.3",
    "solc": "^0.8.28",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
